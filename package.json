{
  "name": "tinyclaw",
  "version": "0.0.10",
  "description": "Multi-agent, multi-team, multi-channel 24/7 AI assistant",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.visualizer.json && echo '{\"type\":\"module\"}' > dist/visualizer/package.json",
    "build:main": "tsc",
    "build:visualizer": "tsc -p tsconfig.visualizer.json && echo '{\"type\":\"module\"}' > dist/visualizer/package.json",
    "test:task-linkage": "npm run build:main && node --test tests/task-linkage-workflow.test.js",
    "test:task-linkage:integration": "npm run build:main && node --test tests/task-linkage-execution.test.js",
    "test:task-linkage:runtime": "npm run build:main && node --test tests/task-linkage-runtime.test.js",
    "test:task-linkage:runtime:team-chain": "npm run build:main && node --test tests/task-linkage-team-chain-runtime.test.js",
    "test:task-linkage:runtime:reviewer-pr": "npm run build:main && node --test tests/reviewer-pr-linkage-runtime.test.js",
    "test:task-linkage:runtime:reviewer-pr-fetch": "npm run build:main && node --test tests/reviewer-pr-fetch-runtime.test.js",
    "test:task-linkage:runtime:tester-pr": "npm run build:main && node --test tests/tester-pr-linkage-runtime.test.js",
    "test:task-linkage:runtime:tester-pr-fetch": "npm run build:main && node --test tests/tester-pr-fetch-runtime.test.js",
    "test:prompt-context-budget": "npm run build:main && node --test tests/prompt-context-budget.test.js",
    "test:coder-worker:runtime": "npm run build:main && node --test tests/coder-worker-runtime.test.js",
    "test:coder-worker:cli-runtime": "npm run build:main && node --test tests/coder-worker-cli-runtime.test.js",
    "test:observability": "npm run build:main && node --test tests/observability-events.test.js",
    "whatsapp": "node dist/channels/whatsapp-client.js",
    "discord": "node dist/channels/discord-client.js",
    "telegram": "node dist/channels/telegram-client.js",
    "slack": "node dist/integrations/slack/slack-client.js",
    "queue": "node dist/queue-processor.js",
    "visualize": "node dist/visualizer/team-visualizer.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.14.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "better-sqlite3": "^12.6.2",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.0",
    "hono": "^4.12.1",
    "ink": "^6.7.0",
    "ink-gradient": "^4.0.0",
    "ink-spinner": "^5.0.0",
    "jsonrepair": "^3.13.2",
    "node-telegram-bot-api": "^0.67.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.4",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "@types/node-telegram-bot-api": "^0.64.13",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.9.3"
  }
}
